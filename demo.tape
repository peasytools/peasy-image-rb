# peasy-image-rb — Image resize, crop, convert (Ruby)
# Theme: One Dark
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "OneDark"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasy-image-rb — Image resize, crop, convert for Ruby"
Enter
Type "# peasyimage.com"
Enter
Sleep 500ms

# Run the demo
Type "ruby -I lib examples/demo.rb"
Enter
Sleep 5s
